COMFYUI_AUTOSTART=1
COMFYUI_BASE_URL=http://127.0.0.1:8188
COMFYUI_WORKSPACE=/opt/ComfyUI
COMFYUI_PORT=8188
COMFYUI_EXTRA_ARGS=
COMFYUI_STARTUP_TIMEOUT_SEC=180
COMFYUI_LOG_PATH=/tmp/englishbot-comfyui.log
COMFYUI_CHECKPOINT_NAME=v1-5-pruned-emaonly.safetensors
COMFYUI_CHECKPOINT_URL=https://huggingface.co/sd-legacy/stable-diffusion-v1-5/resolve/main/v1-5-pruned-emaonly.safetensors
COMFYUI_VAE_NAME=
COMFYUI_VAE_URL=

